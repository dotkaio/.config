#!/usr/bin/env bash

set -euo pipefail

BREW_BIN="/opt/homebrew/bin/brew"
BREW_BIN_INTEL="/usr/local/bin/brew"

# Resolve brew binary path
if [[ -x "$BREW_BIN" ]]; then
  BREW="$BREW_BIN"
elif [[ -x "$BREW_BIN_INTEL" ]]; then
  BREW="$BREW_BIN_INTEL"
else
  BREW=""
fi

install_brew() {
  echo "Homebrew not found. Installing..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"

  # Re-evaluate path after install
  if [[ -x "$BREW_BIN" ]]; then
    BREW="$BREW_BIN"
  elif [[ -x "$BREW_BIN_INTEL" ]]; then
    BREW="$BREW_BIN_INTEL"
  else
    echo "Error: Homebrew installation failed or brew binary not found." >&2
    exit 1
  fi

  echo "Homebrew installed successfully."
}

update_brew() {
  echo "Updating Homebrew..."
  "$BREW" update
  echo "Upgrading outdated packages..."
  "$BREW" upgrade
  echo "Homebrew is up to date."
}

main() {
  if [[ -z "$BREW" ]]; then
    install_brew
    update_brew
  else
    echo "Homebrew is already installed: $("$BREW" --version | head -1)"
    update_brew
  fi
}

main

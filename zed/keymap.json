[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-e": "command_palette::Toggle",
      "cmd-g": "file_finder::Toggle",
      "ctrl-l": "go_to_line::Toggle",
      "cmd-l": "language_selector::Toggle",
      "cmd-o": "workspace::Open",
      "shift-cmd-o": "workspace::Open",
      "shift-cmd-,": "zed::OpenSettingsFile",
      "shift-cmd-\\": "project_panel::ToggleFocus",
      "shift-cmd-.": "terminal_panel::ToggleFocus",
      "ctrl-\\": "workspace::ToggleRightDock",
      "shift-alt-cmd-\\": "workspace::ToggleAllDocks",
      "cmd-.": "terminal_panel::Toggle",
      "shift-alt-cmd-.": "workspace::ToggleZoom",
      "shift-alt-cmd-n": "workspace::NewWindow",
      "shift-cmd-r": "editor::RevealInFileManager",
      "shift-cmd-a": "agent::Toggle",
      "shift-cmd-d": "agent::ToggleFocus",
      "ctrl-shift-\\": "agent::ToggleFocus",
      "cmd-q": "zed::Quit",
      "cmd-r": "debugger::Rerun",
      "ctrl-cmd-r": "debugger::Stop",
      "ctrl-alt-cmd-r": "workspace::Reload",
      "cmd-0": "zed::ResetAllZoom",
      "shift-cmd-f": [
        "pane::DeploySearch",
        {
          "replace_enabled": true
        }
      ]
    }
  },
  {
    "context": "( !Terminal)",
    "bindings": {
      "cmd-t": "workspace::NewFile"
    }
  },
  {
    "context": "!Editor",
    "bindings": {
      "ctrl-cmd-up": [
        "workspace::IncreaseActiveDockSize",
        {
          "px": 0
        }
      ],
      "ctrl-cmd-down": [
        "workspace::DecreaseActiveDockSize",
        {
          "px": 0
        }
      ]
    }
  },
  {
    "context": "Editor && mode == full",
    "bindings": {
      "cmd-p": "editor::GoToDiagnostic",
      "shift-cmd-p": "editor::GoToPreviousDiagnostic",
      "shift-alt-p": "editor::ToggleCodeActions",
      "alt-cmd-p": "editor::ToggleCodeActions",
      "shift-alt-cmd-p": "editor::ToggleCodeActions",
      "alt-f": "editor::Format",
      "alt-\\": "editor::ShowEditPrediction",
      "ctrl-/": "editor::AcceptEditPrediction",
      "ctrl-]": "editor::MoveToEnclosingBracket",
      "ctrl-shift-]": "editor::SelectLargerSyntaxNode",
      "ctrl-shift-alt-up": "editor::AddSelectionAbove",
      "ctrl-shift-alt-down": "editor::AddSelectionBelow",
      "ctrl-cmd-up": "editor::MoveLineUp",
      "ctrl-cmd-down": "editor::MoveLineDown",
      "alt-cmd-left": "workspace::ActivatePaneLeft",
      "alt-cmd-right": "workspace::ActivatePaneRight",
      "alt-cmd-up": "workspace::ActivatePaneUp",
      "alt-cmd-down": "workspace::ActivatePaneDown",
      "ctrl-alt-cmd-left": "pane::SplitAndMoveLeft",
      "ctrl-alt-cmd-right": "pane::SplitAndMoveRight",
      "ctrl-alt-cmd-up": "pane::SplitAndMoveUp",
      "ctrl-alt-cmd-down": "pane::SplitAndMoveDown",
      "cmd-k 1": "editor::FoldAtLevel_1",
      "cmd-k 2": "editor::FoldAtLevel_2",
      "cmd-k 3": "editor::FoldAtLevel_3",
      "cmd-k 4": "editor::FoldAtLevel_4",
      "shift-alt-cmd-[": "editor::FoldAll",
      "shift-alt-cmd-]": "editor::UnfoldAll",
      "shift-cmd-o": "outline::Toggle"
    }
  },
  {
    "context": "Editor && extension == md",
    "bindings": {
      "shift-cmd-v": "markdown::OpenPreviewToTheSide",
      "shift-alt-v": "markdown::OpenPreview"
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "cmd-1": ["pane::ActivateItem", 0],
      "cmd-2": ["pane::ActivateItem", 1],
      "cmd-3": ["pane::ActivateItem", 2],
      "cmd-4": ["pane::ActivateItem", 3],
      "cmd-5": ["pane::ActivateItem", 4],
      "cmd-6": ["pane::ActivateItem", 5],
      "cmd-7": ["pane::ActivateItem", 6],
      "cmd-8": ["pane::ActivateItem", 7],
      "cmd-9": ["pane::ActivateItem", 8],
      "shift-cmd-]": "pane::ActivateNextItem",
      "cmd-w": "pane::CloseActiveItem"
    }
  },
  {
    "context": "Panel",
    "bindings": {
      "shift-cmd-]": "panel::NextPanelTab",
      "shift-cmd-[": "panel::PreviousPanelTab"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "right": "project_panel::Open",
      "cmd-right": "project_panel::Open",
      "cmd-n": "project_panel::NewDirectory",
      "cmd-t": "project_panel::NewFile"
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal",
      "cmd-w": "pane::CloseActiveItem",
      "alt-cmd-down": "pane::ActivateNextItem",
      "alt-cmd-up": "pane::ActivatePreviousItem"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-p": null
    }
  },
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "cmd-e": null
    }
  },
  {
    "context": "KeymapEditor",
    "bindings": {
      "cmd-e": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-\\": null
    }
  },
  {
    "bindings": {
      "cmd-\\": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-|": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-shift-e": "project_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "cmd-shift-g": "git_panel::ToggleFocus"
    }
  },
  {
    "bindings": {
      "cmd-shift-x": "zed::Extensions"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-shift-x": null
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-t": null
    }
  },
  {
    "context": "DebugPanel",
    "bindings": {
      "cmd-t": null
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "cmd-.": null
    }
  },
  {
    "bindings": {
      "cmd-|": "project_panel::Open"
    }
  }
]

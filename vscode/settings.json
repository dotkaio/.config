{
  "[csv]": {
    "editor.inlayHints.maximumLength": 0,
    "editor.wordWrap": "off"
  },
  "[dotenv]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev"
  },
  "[html]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[ignore]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev"
  },
  "[javascript]": {
    "editor.wordWrapColumn": 90
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[jsonl]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[properties]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev"
  },
  "[python]": {
    "editor.defaultFormatter": "ms-python.autopep8",
  },
  "[shellscript]": {
    "editor.defaultFormatter": "lumirelle.shell-format-rev",
    "files.eol": "\n"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.wordWrapColumn": 90
  },
  // "terminal.integrated.scrollback": 100000,
  "chat.agent.maxRequests": 10000,
  "chat.agent.thinkingStyle": "collapsed",
  "chat.checkpoints.showFileChanges": true,
  "chat.instructionsFilesLocations": {
    "~/.claude/instructions": false
  },
  "chat.mcp.gallery.enabled": true,
  "chat.mcp.serverSampling": {
    "Global in Code: firecrawl/firecrawl-mcp-server": {
      "allowedModels": [
        "copilot/gpt-5-mini",
        "copilot/claude-opus-4.6",
        "copilot/gemini-3-pro-preview",
        "copilot/gpt-5.3-codex"
      ]
    },
    "Global in Code: io.github.ChromeDevTools/chrome-devtools-mcp": {
      "allowedModels": [
        "copilot/claude-opus-4.6",
        "copilot/gpt-5.3-codex"
      ]
    },
    "Global in Code: microsoft/playwright-mcp": {
      "allowedModels": [
        "copilot/claude-opus-4.6",
        "copilot/gpt-5.3-codex"
      ]
    },
    "Global in Code: neondatabase/mcp-server-neon": {
      "allowedModels": [
        "copilot/claude-opus-4.6",
        "copilot/gpt-5.3-codex"
      ]
    }
  },
  "chat.requestQueuing.defaultAction": "queue",
  "chat.tools.edits.autoApprove": {
    "**/*-lock.{yaml,json}": true,
    "**/*.lock": true,
    "**/*.{code-workspace,csproj,fsproj,vbproj,vcxproj,proj,targets,props}": true,
    "**/.git/**": true,
    "**/.github/**": true,
    "**/.vscode/*.json": true,
    "**/{package.json,server.xml,build.rs,web.config,.gitattributes,.env}": true
  },
  "chat.tools.terminal.autoApprove": {
    "*": true,
    "bash": true,
    "cat": true,
    "cp": true,
    "curl": true,
    "git": true,
    "grep": true,
    "kill": true,
    "ls": true,
    "lsof": true,
    "mkdir": true,
    "mv": true,
    "node": true,
    "npm": true,
    "npx": true,
    "pip": true,
    "pip3": true,
    "pnpm": true,
    "python": true,
    "rm": true,
    "sh": true,
    "shellscript": true,
    "vercel": true,
    "wget": true,
    "yarn": true,
    "zsh": true
  },
  "chat.tools.terminal.enableAutoApprove": true,
  "chat.tools.urls.autoApprove": {
    "https://*.better-auth.com": true,
    "https://*.npmjs.com": true,
    "https://bcpa.net": true,
    "https://bcpa.net/DataFiles.asp": true,
    "https://bcpa.net/NAL.asp": true,
    "https://bcpa.net/TOC.asp": true,
    "https://github.com": true,
    "https://github.com/usewaypoint": true,
    "https://github.com/usewaypoint/email-builder-js": true
  },
  // show all chat sessions and remove the MORE(<total>) button
  "chat.viewSessions.enabled": true,
  "css.lint.unknownAtRules": "ignore",
  "editor.bracketPairColorization.enabled": false,
  "editor.colorDecoratorsActivatedOn": "click",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.find.seedSearchStringFromSelection": "selection",
  "editor.fontFamily": "SF Mono, Monaco, 'Courier New', monospace",
  "editor.formatOnPaste": true,
  // "editor.fontFamily": "SF Mono, Monaco, 'Courier New', monospace",
  // "editor.fontSize": 13,
  "editor.minimap.enabled": false,
  "editor.pasteAs.preferences": [
    "chat.attach.attachments"
  ],
  "editor.renderControlCharacters": false,
  "editor.renderWhitespace": "none",
  "editor.scrollBeyondLastColumn": 0,
  "editor.scrollBeyondLastLine": false,
  "editor.scrollPredominantAxis": false,
  "editor.scrollbar.verticalScrollbarSize": 5,
  "editor.stickyScroll.enabled": false,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "emmet.showAbbreviationSuggestions": true,
  "emmet.showExpandedAbbreviation": "never",
  "emmet.showSuggestionsAsSnippets": true,
  "explorer.autoReveal": "focusNoScroll",
  "explorer.compactFolders": false,
  "explorer.confirmDelete": true,
  "files.associations": {
    "*.applescript": "applescript",
    "*.bash": "shellscript",
    "*.bashrc": "shellscript",
    "*.csv": "csv",
    "*.lock": "json",
    "*.md": "markdown",
    "*.scpt": "applescript",
    "*.sh": "shellscript",
    "*.xls": "csv",
    "*.zsh": "shellscript",
    ".env": "shellscript"
  },
  "git.confirmSync": false,
  "git.openRepositoryInParentFolders": "never",
  "github.copilot.chat.agent.autoFix": true,
  "github.copilot.chat.copilotMemory.enabled": true,
  "github.copilot.chat.updated53CodexPrompt.enabled": true,
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": true,
    "javascript": true,
    "json": true,
    "jsonc": true,
    "python": true,
    "shellscript": true,
    "typescript": true,
    "typescriptreact": true
  },
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.selectedCompletionModel": "",
  "html.format.wrapLineLength": 0,
  "inlineChat.defaultModel": "GPT-5.3-Codex (copilot)",
  "json.schemaDownload.trustedDomains": {
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://openapi.vercel.sh": true,
    "https://raw.githubusercontent.com/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://ui.shadcn.com": true,
    "https://www.schemastore.org/": true
  },
  // "python.analysis.enableColorPicker": false,
  // "python.experiments.enabled": false,
  // "python.experiments.optOutFrom": [
  //   "All",
  //   "pythonPromptNewToolsExt",
  //   "pythonSurveyNotification",
  //   "pythonTerminalEnvVarActivation",
  //   "pythonTestAdapter",
  //   "pythonDiscoveryUsingWorkers"
  // ],
  "redhat.telemetry.enabled": false,
  "remote.autoForwardPorts": false,
  "scm.alwaysShowRepositories": true,
  "scm.defaultViewMode": "tree",
  "scss.lint.unknownAtRules": "ignore",
  "settingsSync.keybindingsPerPlatform": false,
  "shellformat.effectLanguages": [
    "bash",
    "zsh",
    "sh",
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties"
  ],
  "shellformat.path": "/opt/homebrew/bin/shfmt",
  "telemetry.telemetryLevel": "off",
  "terminal.external.osxExec": "iTerm.app",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorStyleInactive": "block",
  "terminal.integrated.customGlyphs": false,
  "terminal.integrated.enableFileLinks": "off",
  "terminal.integrated.environmentChangesRelaunch": false,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.shellIntegration.environmentReporting": true,
  "terminal.integrated.stickyScroll.enabled": false,
  "update.showReleaseNotes": false,
  "window.autoDetectColorScheme": true,
  "window.commandCenter": false,
  "window.newWindowDimensions": "inherit",
  "window.restoreWindows": "all",
  "window.title": "${activeEditorLong} - ${rootName}",
  "workbench.colorCustomizations": {
    "[Atom One Light]": {
      "focusBorder": "#3586FF",
      "list.focusOutline": "#3586FF",
      "panel.background": "#ebebec",
      "sideBar.border": "#e0e0e1",
      // "terminal.ansiBlue": "#007aff",
      // "terminal.ansiBrightGreen": "#6eff7f",
      // "terminal.ansiBrightRed": "#ff6e6e",
      // "terminal.ansiBrightYellow": "#ffd633",
      // "terminal.ansiGreen": "#4cd964",
      // "terminal.ansiMagenta": "#ff23fb",
      // "terminal.ansiRed": "#f85c5c",
      // "terminal.ansiYellow": "#ffcc00",
      "sideBySideEditor.verticalBorder": "#3586FF",
      "terminal.background": "#ebebec",
      "terminal.selectionBackground": "#a5cdff"
    },
    "[One Dark Pro Mix]": {
      "editorCursor.foreground": "#3586FF",
      "list.focusBackground": "#3586ff37",
      "list.focusOutline": "#3586FF",
      "widget.border": "#3586FF",
      "focusBorder": "#3586FF",
      "panel.background": "#21252b",
      "activityBar.activeBorder": "#c7ccd6",
      "terminal.background": "#21252b",
      "terminal.selectionBackground": "#a5cdff"
      // "sideBar.border": "#282c34",
      // "terminal.ansiBlue": "#007aff",
      // "terminal.ansiBrightGreen": "#6eff7f",
      // "terminal.ansiBrightRed": "#ff6e6e",
      // "terminal.ansiBrightYellow": "#ffd633",
      // "terminal.ansiGreen": "#4cd964",
      // "terminal.ansiMagenta": "#ff23fb",
      // "terminal.ansiRed": "#f85c5c",
      // "terminal.ansiYellow": "#ffcc00",
    },
  },
  "editor.useTabStops": true,
  "editor.insertSpaces": false,
  "editor.detectIndentation": true,
  "workbench.editor.empty.hint": "hidden",
  "workbench.editor.enablePreview": false,
  "workbench.editor.restoreEditors": false,
  "workbench.editor.restoreViewState": true,
  "workbench.editorAssociations": {
    "*.markdown": "default",
    "*.md": "default"
  },
  "workbench.enableExperiments": false,
  "workbench.layoutControl.enabled": false,
  "workbench.navigationControl.enabled": false,
  "workbench.preferredDarkColorTheme": "One Dark Pro Mix",
  "workbench.preferredLightColorTheme": "Atom One Light",
  "workbench.secondarySideBar.defaultVisibility": "hidden",
  "workbench.startupEditor": "none",
  "workbench.tree.enableStickyScroll": false,
  "chat.editing.confirmEditRequestRemoval": false,
  "chat.agentSkillsLocations": {
    "~/.agents": true,
    "~/.agents/skills": true,
    "~/.claude/skills": false,
    "~/.copilot/skills": false,
    ".claude/skills": false,
    ".github/skills": false,
  },
  "chat.experimental.useSkillAdherencePrompt": true,
  "chat.autoReply": true,
  "editor.autoIndent": "full",
  "editor.foldingStrategy": "indentation",
  "terminal.integrated.scrollback": 1000000,
  "chat.useNestedAgentsMdFiles": true,
  "editor.wordWrap": "on",
  "chat.tools.terminal.outputLocation": "terminal",
  "claudeCode.preferredLocation": "panel",
  "chat.viewSessions.orientation": "stacked",
  // "explorer.excludeGitIgnore": true,
}
{
  "shellformat.path": "/opt/homebrew/bin/shfmt",
  "[markdown]": {
    "editor.wordWrap": "off",
    "editor.rulers": [],
  },
  "[csv]": {
    "editor.inlayHints.maximumLength": 0,
    "editor.wordWrap": "off",
    "editor.rulers": [],
  },
  "[ignore]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "[properties]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[shellscript]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
    "files.eol": "\n",
  },
  "accessibility.signals.terminalBell": {
    "announcement": "off",
    "sound": "off",
  },
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "chat.agent.thinking.collapsedTools": "always",
  "chat.agent.thinking.terminalTools": false,
  "chat.agent.thinkingStyle": "collapsed",
  "chat.checkpoints.showFileChanges": true,
  "chat.editing.confirmEditRequestRemoval": false,
  "chat.exploreAgent.defaultModel": "Claude Haiku 4.5 (copilot)",
  "chat.checkpoints.enabled": true,
  "chat.instructionsFilesLocations": {
    ".claude/instructions": false,
    ".github/instructions": true,
    "~/.claude/instructions": false,
    "~/.copilot/instructions": false,
    "~/.claude/rules": false,
    ".claude/rules": false,
    "~/.agents/instructions": false
  },
  "chat.mcp.gallery.enabled": true,
  "chat.planAgent.defaultModel": "GPT-5.3-Codex (copilot)",
  "chat.promptFilesLocations": {
    "~/.agents/prompts": true,
  },
  "chat.tools.urls.autoApprove": {
    "https://*.better-auth.com": true,
    "https://*.npmjs.com": true,
    "https://bcpa.net": true,
    "https://bcpa.net/DataFiles.asp": true,
    "https://bcpa.net/NAL.asp": true,
    "https://bcpa.net/TOC.asp": true,
    "https://github.com": true,
    "https://github.com/usewaypoint": true,
    "https://github.com/usewaypoint/email-builder-js": true,
    "https://lucide.dev": true,
  },
  "chat.useAgentSkills": true,
  "chat.viewSessions.orientation": "stacked",
  // "diffEditor.renderSideBySide": false,
  "editor.find.seedSearchStringFromSelection": "always",
  "editor.insertSpaces": false,
  "editor.lightbulb.enabled": "off",
  "editor.minimap.enabled": false,
  "editor.renderControlCharacters": false,
  // "editor.renderLineHighlight": "all",
  "editor.scrollbar.verticalScrollbarSize": 5,
  "editor.scrollBeyondLastColumn": 0,
  "editor.scrollBeyondLastLine": false,
  "editor.scrollPredominantAxis": false,
  "editor.stickyScroll.enabled": false,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.tabSize": 2,
  "editor.unicodeHighlight.includeComments": false,
  "editor.wordWrapColumn": 80,
  "editor.rulers": [
    80
  ],
  // "terminal.integrated.tabs.defaultIcon": "comment",
  "editor.wrappingIndent": "deepIndent",
  // "emmet.showAbbreviationSuggestions": true,
  // "emmet.showExpandedAbbreviation": "never",
  // "emmet.showSuggestionsAsSnippets": true,
  "explorer.excludeGitIgnore": true,
  "extensions.ignoreRecommendations": true,
  "files.associations": {
    ".env": "shellscript",
    "*.applescript": "applescript",
    "*.bash": "shellscript",
    "*.bashrc": "shellscript",
    "*.csv": "csv",
    "*.lock": "json",
    "*.md": "markdown",
    "*.scpt": "applescript",
    "*.sh": "shellscript",
    "*.xls": "csv",
    "*": "shellscript",
  },
  "github.copilot.enable": {
    "*": true,
    "javascript": true,
    "json": true,
    "jsonc": true,
    "markdown": true,
    "plaintext": true,
    "python": true,
    "scminput": true,
    "shellscript": true,
    "typescript": true,
    "typescriptreact": true,
  },
  "editor.renderWhitespace": "none",
  "github.copilot.nextEditSuggestions.enabled": true,
  "github.copilot.selectedCompletionModel": "copilot/gpt-5.3-codex",
  "html.format.wrapLineLength": 0,
  "chat.tools.terminal.outputLocation": "terminal",
  "inlineChat.defaultModel": "GPT-5.4 (copilot)",
  "inlineChat.enableV2": false,
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "json.schemaDownload.trustedDomains": {
    "https://json-schema.org/": true,
    "https://json.schemastore.org/": true,
    "https://openapi.vercel.sh": true,
    "https://raw.githubusercontent.com/": true,
    "https://schemastore.azurewebsites.net/": true,
    "https://ui.shadcn.com": true,
    "https://www.schemastore.org/": true,
  },
  "remote.autoForwardPorts": false,
  "scm.alwaysShowRepositories": true,
  "settingsSync.keybindingsPerPlatform": false,
  "shellformat.effectLanguages": [
    "bash",
    "zsh",
    "sh",
    "shellscript",
    "dockerfile",
    "dotenv",
    "hosts",
    "jvmoptions",
    "ignore",
    "gitignore",
    "properties",
  ],
  "telemetry.telemetryLevel": "off",
  "terminal.integrated.bellDuration": 0,
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.cursorStyle": "block",
  "terminal.integrated.cursorStyleInactive": "block",
  "terminal.integrated.customGlyphs": false,
  "terminal.integrated.enableFileLinks": "off",
  "terminal.integrated.environmentChangesRelaunch": false,
  "terminal.integrated.inheritEnv": false,
  "terminal.integrated.initialHint": false,
  "terminal.integrated.scrollback": 1000000,
  "terminal.integrated.shellIntegration.decorationsEnabled": "never",
  "terminal.integrated.shellIntegration.environmentReporting": true,
  "terminal.integrated.stickyScroll.enabled": false,
  "update.showReleaseNotes": false,
  "window.autoDetectColorScheme": true,
  "window.density.editorTabHeight": "compact",
  "window.newWindowDimensions": "inherit",
  "window.restoreWindows": "all",
  "window.title": "${rootName}${separator}${activeEditorMedium}",
  "workbench.colorCustomizations": {
    "[Atom One Dark]": {
      // make the text on the explorer more dim
      "list.inactiveSelectionForeground": "#ffffff99",
      "activityBar.activeBackground": "#21252b",
      "activityBar.activeBorder": "#21252b",
      "panel.background": "#21252b",
      "scrollbar.shadow": "#ffffff00",
      "terminal.foreground": "#dbdcde",
      "terminalCursor.foreground": "#65a0ff",
    },
    "[Atom One Light]": {
      "activityBar.activeBackground": "#eaeaeb",
      "activityBar.activeBorder": "#eaeaeb",
      "statusBar.border": "#85858579",
      "statusBar.foreground": "#5b5b5b",
      "terminal.foreground": "#dbdcde",
      "widget.shadow": "#00000000",
      "panel.background": "#eaeaeb",
      "scrollbar.shadow": "#ffffff00",
      "terminalCursor.foreground": "#65a0ff",
      "terminal.selectionBackground": "#5a96f6",
    },
  },
  "breadcrumbs.enabled": false,
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "workbench.editor.editorActionsLocation": "titleBar",
  "workbench.editor.enablePreview": false,
  "workbench.editor.restoreEditors": false,
  "workbench.editor.restoreViewState": true,
  "workbench.editorAssociations": {
    "*.markdown": "default",
    "*.md": "default",
  },
  "workbench.enableExperiments": false,
  "workbench.preferredHighContrastColorTheme": "Atom One Dark",
  "workbench.preferredHighContrastLightColorTheme": "Atom One Light",
  "workbench.reduceTransparency": "on",
  "workbench.tree.enableStickyScroll": false,
  // "workbench.editor.tabSizing": "shrink",
  "workbench.editor.titleScrollbarVisibility": "hidden",
  "explorer.compactFolders": false,
  "editor.autoClosingBrackets": "languageDefined",
  "explorer.confirmUndo": "verbose",
  "workbench.layoutControl.type": "menu",
  "workbench.browser.dataStorage": "ephemeral",
  "workbench.startupEditor": "newUntitledFile",
  "chat.tools.terminal.autoApprove": {
    "pnpm exec eslint": true,
    "command": true
  },
  "git.openRepositoryInParentFolders": "never",
  "workbench.preferredDarkColorTheme": "Atom One Dark",
  "workbench.preferredLightColorTheme": "Atom One Light",
  "debug.console.wordWrap": false,
  "workbench.editor.empty.hint": "hidden",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "security.promptForRemoteFileProtocolHandling": false,
  "chat.agent.maxRequests": 1000,
  "chat.experimental.useSkillAdherencePrompt": true,
  "github.copilot.chat.getSearchViewResultsSkill.enabled": true,
  "chat.editor.wordWrap": "on",
  "workbench.colorTheme": "Atom One Light",
  "editor.mouseWheelZoom": false,
  "editor.formatOnPaste": true,
  "editor.wrapOnEscapedLineFeeds": true,
  "editor.wrappingStrategy": "advanced",
  "editor.wordWrap": "wordWrapColumn",
  "window.closeWhenEmpty": false,
  "workbench.settings.alwaysShowAdvancedSettings": true,
  "workbench.editor.useModal": "off",
  "chat.sendElementsToChat.attachCSS": false,
  "chat.unifiedAgentsBar.enabled": true,
  "workbench.experimental.share.enabled": true,
  "github.copilot.nextEditSuggestions.eagerness": "high",
  "git.enableSmartCommit": true,
  "workbench.browser.enableChatTools": true,
  "workbench.browser.showInTitleBar": true,
}